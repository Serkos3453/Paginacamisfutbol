# Django Settings
SECRET_KEY=your-django-secret-key
DEBUG=True

# Supabase (PostgreSQL) Connection
# Replace with your connection string from Supabase -> Project Settings -> Database -> Connection string -> URI
# Example: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.reference.supabase.co:5432/postgres
